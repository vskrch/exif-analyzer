# ============================================
# EXIF Analyzer - Environment Configuration
# ============================================
# Copy this file to .env and fill in values

# App
APP_NAME=EXIF Analyzer
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production

# Database
DATABASE_URL=sqlite:///./exif_analyzer.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/exif_analyzer

# Redis (for rate limiting & caching)
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-very-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.tiff,.tif,.webp,.heic,.heif,.bmp,.gif

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_UPLOAD_PER_MINUTE=10

# Stripe (for SaaS billing - optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FREE_TIER_MONTHLY_ANALYSES=50
STRIPE_PRO_TIER_MONTHLY_ANALYSES=1000

# Email (for password reset etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@exifanalyzer.com

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
